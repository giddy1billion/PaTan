# Session
SESSION_SECRET=replace-with-a-long-random-secret
APP_ORIGIN=http://localhost:5173

# Security Email Delivery (Resend primary)
RESEND_API_KEY=
AUTH_EMAIL_FROM=PaTan Security <security@notifications.patan.app>


# Security Email Delivery fallback (optional webhook that receives email payloads)
AUTH_EMAIL_WEBHOOK_URL=
AUTH_EMAIL_WEBHOOK_SECRET=
AUTH_EMAIL_WEBHOOK_KEY_ID=

# Security Alerts (optional webhook for high/critical auth events)
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_WEBHOOK_SECRET=
SECURITY_ALERT_WEBHOOK_KEY_ID=



# CSRF
# Uses signed cookie-based synchronizer token automatically.

# Bot Defense (Turnstile by default)
BOT_DEFENSE_ENABLED=true
BOT_DEFENSE_PROVIDER=turnstile
BOT_DEFENSE_MIN_SCORE=0.5

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google reCAPTCHA v2/v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Bot challenge thresholds (failed attempts in rolling window)
BOT_CHALLENGE_LOGIN_FAILURE_THRESHOLD=3
BOT_CHALLENGE_SIGNUP_FAILURE_THRESHOLD=2
BOT_CHALLENGE_PASSWORD_RESET_THRESHOLD=2

# Password security
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_BREACHED_PASSWORD_CHECK=true

# Email verification and reset token lifetimes (milliseconds)
AUTH_EMAIL_VERIFICATION_TTL_MS=86400000
AUTH_PASSWORD_RESET_TTL_MS=3600000

# Email verification retry worker tuning
AUTH_EMAIL_VERIFICATION_RETRY_BASE_DELAY_MS=120000
AUTH_EMAIL_VERIFICATION_RETRY_MAX_ATTEMPTS=6
AUTH_EMAIL_VERIFICATION_RETRY_BATCH_SIZE=20
AUTH_EMAIL_VERIFICATION_RETRY_LOOP_MS=60000
AUTH_EMAIL_VERIFICATION_RETRY_CONCURRENCY=5
AUTH_EMAIL_VERIFICATION_DELIVERY_TIMEOUT_MS=15000
AUTH_EMAIL_VERIFICATION_WORKER_RUN_TIMEOUT_MS=90000
AUTH_EMAIL_VERIFICATION_RETRY_DELIVERED_RETENTION_DAYS=30


# Rate-limit policy overrides (optional, per scope)
# Format: AUTH_RATE_LIMIT_<SCOPE>_<DIMENSION>_<FIELD>
# Scopes: LOGIN, SIGNUP, OAUTH_INIT, OAUTH_CALLBACK, PASSWORD_RESET, MFA, AI_SUGGEST
# Dimensions: IP, IDENTIFIER
# Fields: WINDOW_MS, MAX, BLOCK_MS
# Example:
# AUTH_RATE_LIMIT_LOGIN_IP_WINDOW_MS=900000
# AUTH_RATE_LIMIT_LOGIN_IP_MAX=20
# AUTH_RATE_LIMIT_LOGIN_IP_BLOCK_MS=1800000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_REDIRECT_URI=http://localhost:5173/oauth/callback
