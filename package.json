{
  "name": "PaTan™",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:brand": "tsx scripts/generate-brand-assets.ts",
    "generate:logos": "tsx scripts/generate-brand-assets.ts logos",
    "generate:icons": "tsx scripts/generate-brand-assets.ts icons",
    "generate:social": "tsx scripts/generate-brand-assets.ts social",
    "generate:png": "tsx scripts/convert-svg-to-png.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-router/node": "7.16.0",
    "@react-router/serve": "7.16.0",
    "dotenv": "^17.4.2",
    "isbot": "^5.1.36",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.16.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^7.8.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.8"
  }
}
